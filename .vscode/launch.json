{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hosted workbench",
      "type": "node",
      "request": "launch",
      "runtimeArgs": [
        "-e",
        "console.log(require('child_process').execSync('npm run start', { cwd: process.cwd(), stdio: 'inherit' }).toString())"
      ],
      "runtimeExecutable": "node",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
