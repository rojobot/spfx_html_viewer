{
  "name": "spfx-html-viewer",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rojobot/spfx_html_viewer.git"
  },
  "engines": {
    "node": ">=18.17.1 <19.0.0 || >=20.11.0 <21.0.0"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "gulp bundle",
    "clean": "gulp clean",
    "test": "jest --config ./config/jest/jest.config.json --coverage",
    "test:watch": "jest --config ./config/jest/jest.config.json --watchAll",
    "test:full": "gulp test",
    "package": "gulp bundle --ship && gulp package-solution --ship",
    "package:embedded": "node scripts/restore-embedded-config.mjs && gulp bundle --ship && gulp package-solution --ship",
    "prepare:cdn": "node scripts/prepare-cdn.mjs",
    "package:cdn": "node scripts/prepare-cdn.mjs && gulp bundle --ship && gulp deploy-azure-storage && gulp package-solution --ship",
    "verify-versions": "node scripts/verify-versions.mjs",
    "sync-catalog-metadata": "node scripts/sync-catalog-metadata.mjs"
  },
  "dependencies": {
    "@microsoft/sp-component-base": "1.20.0",
    "@microsoft/sp-core-library": "1.20.0",
    "@microsoft/sp-lodash-subset": "1.20.0",
    "@microsoft/sp-office-ui-fabric-core": "1.20.0",
    "@microsoft/sp-property-pane": "1.20.0",
    "@microsoft/sp-webpart-base": "1.20.0",
    "@pnp/logging": "1.3.11",
    "@pnp/spfx-property-controls": "3.20.0",
    "tslib": "2.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@microsoft/eslint-config-spfx": "1.20.2",
    "@microsoft/eslint-plugin-spfx": "1.20.2",
    "@microsoft/rush-stack-compiler-4.7": "0.1.0",
    "@microsoft/sp-build-web": "1.20.2",
    "@microsoft/sp-module-interfaces": "1.20.2",
    "@rushstack/eslint-config": "4.0.1",
    "@types/jest": "25.2.1",
    "@types/webpack-env": "~1.15.2",
    "ajv": "^6.12.5",
    "babel-jest": "~25.5.1",
    "eslint": "8.57.0",
    "gulp": "4.0.2",
    "jest": "~25.4.0",
    "typescript": "4.7.4"
  }
}
