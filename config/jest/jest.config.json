{
  "testEnvironment": "node",
  "rootDir": "../..",
  "testMatch": ["<rootDir>/src/webparts/htmlViewer/**/*.test.ts"],
  "transform": {
    "^.+\\.tsx?$": "babel-jest"
  },
  "collectCoverageFrom": [
    "src/webparts/htmlViewer/sharePointPath.ts",
    "src/webparts/htmlViewer/propertyValidation.ts",
    "src/webparts/htmlViewer/urlAllowlist.ts",
    "src/webparts/htmlViewer/fileUrlBuilder.ts",
    "src/webparts/htmlViewer/logMessage.ts",
    "src/webparts/htmlViewer/viewerLogger.ts",
    "src/webparts/htmlViewer/viewerLayout.ts"
  ],
  "coverageDirectory": "<rootDir>/temp/coverage"
}
